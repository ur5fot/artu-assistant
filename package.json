{
  "name": "r2-assistant",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "./scripts/dev.sh plain",
    "dev:tailnet": "./scripts/dev.sh tailnet",
    "tailnet:cert": "./scripts/gen-tailnet-cert.sh",
    "dev:tunnel": "./scripts/dev.sh tunnel",
    "dev:named": "./scripts/dev.sh named",
    "dev:server": "npm run dev -w @r2/server",
    "dev:client": "npm run dev -w @r2/client",
    "tunnel": "echo '' > /tmp/r2-cf.yml && cloudflared tunnel --config /tmp/r2-cf.yml --url http://127.0.0.1:$(node -e \"require('dotenv').config({path:'.env'});console.log(process.env.CLIENT_PORT||5173)\")",
    "start": "node packages/supervisor/dist/index.js",
    "start:build": "npm run build -w @r2/shared && npm run build -w @r2/server && npm run build -w @r2/supervisor && npm start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
