ANTHROPIC_API_KEY=sk-ant-...
# Server port (used by server + client proxy in vite.config.ts)
PORT=3001
# Client dev server port (used by Vite + server CORS)
CLIENT_PORT=5173
# Claude model (default: claude-sonnet-4-6)
# Options: claude-sonnet-4-6, claude-opus-4-6
CLAUDE_MODEL=claude-sonnet-4-6
# Max output tokens (default: 16384)
CLAUDE_MAX_TOKENS=16384
# Extended thinking budget in tokens (default: 10240)
CLAUDE_THINKING_BUDGET=10240
# SearXNG URL (default: http://localhost:8888)
SEARXNG_URL=http://localhost:8888
# SQLite database path (default: ./data/r2.db)
# Relative paths resolve from the project root (not process.cwd) —
# safe to start the server from any directory. Absolute paths pass through.
DB_PATH=./data/r2.db
# Root directory for file operations (default: ~/Documents/r2)
R2_FILES_ROOT=~/Documents/r2
# PII Gateway (Phase 2C)
# NOTE: Presidio is FROZEN — docker-compose puts it behind the "pii" profile, so
# `docker compose up -d` does NOT start it. To use PII anonymization: start it with
# `docker compose --profile pii up -d` AND set PII_MODE below to optional/required.
# Mode: required (blocks without Presidio) | optional (warn + pass-through) | disabled
PII_MODE=disabled
# Encryption key for PII token vault (auto-generated on first run if empty)
PII_ENCRYPTION_KEY=
# Entity types to detect (comma-separated Presidio entity names)
PII_ENTITY_TYPES=EMAIL_ADDRESS,PHONE_NUMBER,CREDIT_CARD,IBAN_CODE
# Comma-separated list of languages for PII detection.
# Each language adds one analyzer HTTP call per anonymization request.
# Requires the custom Presidio image with spaCy models for ru/uk (see presidio/Dockerfile).
PII_LANGUAGES=en,ru,uk
# Presidio service URLs
PRESIDIO_ANALYZER_URL=http://localhost:5002
PRESIDIO_ANONYMIZER_URL=http://localhost:5001
# All available Presidio entity types:
# EMAIL_ADDRESS, PHONE_NUMBER, CREDIT_CARD, IBAN_CODE, IP_ADDRESS,
# PERSON, LOCATION, DATE_TIME, NRP, MEDICAL_LICENSE,
# US_SSN, US_DRIVER_LICENSE, UK_NHS, SG_NRIC_FIN, AU_ABN,
# AU_ACN, AU_TFN, AU_MEDICARE, US_PASSPORT, US_BANK_NUMBER
# Supervisor (Phase 3A)
R2_SUPERVISOR_PORT=3100
R2_SHUTDOWN_TIMEOUT=5000
# Client WebSocket URL for supervisor status (set in production)
VITE_SUPERVISOR_WS_URL=ws://localhost:3100
# Phase 3C: Code task
R2_DEV_WORKTREE_PREFIX=/tmp/r2-dev-
R2_DEV_BRANCH=dev
R2_DEV_BASE_BRANCH=master
R2_RALPHEX_MAX_ITERATIONS=20
# Phase 3D: Git watcher + auto-deploy
R2_GIT_POLL_INTERVAL=60000       # ms; 0 = disable watcher
R2_GIT_WATCH_BRANCH=master       # branch to watch for external changes
R2_GIT_REPO_PATH=                # optional, defaults to project root
# Phase 3E: Eval system
EVAL_CONCURRENCY=3
# Relative paths resolve from the project root (not process.cwd) —
# safe to start the server from any directory. Absolute paths pass through.
EVALS_PATH=./data/evals.json
# Phase 4G: Local LLM router
LOCAL_LLM_MODE=enabled            # enabled | disabled (gates chat router; memory falls back to Voyage/Claude when disabled)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_MS=45000
# Set to 1 to allow OLLAMA_URL on non-loopback hosts. Without this, startup
# refuses non-loopback URLs because the Ollama path bypasses PII anonymization.
OLLAMA_ALLOW_REMOTE=
# Memory system — indexes chat history into a local sqlite-vec DB. Embeddings
# come from Ollama (mxbai-embed-large, 1024-dim) or Voyage AI (voyage-3, 1024-dim);
# fact extraction comes from Ollama (qwen2.5:7b) or Claude (Haiku). See
# README "Running R2 without Ollama" for the API-only configuration.
MEMORY_ENABLED=true
# embedding/text provider selection. Note: there is no runtime ping — selection
# is based on env, not Ollama reachability. For full API-only mode, set both
# explicitly (see README "Running R2 without Ollama").
#   EMBEDDING_PROVIDER=auto   → Ollama (set 'voyage' explicitly to use Voyage)
#   MEMORY_TEXT_PROVIDER=auto → Ollama unless LOCAL_LLM_MODE=disabled, then Claude
EMBEDDING_PROVIDER=auto                                  # auto | ollama | voyage
MEMORY_TEXT_PROVIDER=auto                                # auto | ollama | claude
MEMORY_EMBED_MODEL=mxbai-embed-large                     # Ollama embed model (must be 1024-dim)
MEMORY_EXTRACT_MODEL=qwen2.5:7b                          # Ollama extractor model
MEMORY_EXTRACT_MODEL_CLAUDE=claude-haiku-4-5-20251001    # Claude extractor model
# Voyage AI (required when EMBEDDING_PROVIDER=voyage; sign up at https://www.voyageai.com/)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3                                    # voyage-3 | voyage-3-large (both 1024-dim)
# Required acknowledgment when memory uses Voyage or Claude. Raw chat content
# and extracted facts (incl. any PII) flow to those providers without
# anonymization — the memory pipeline does not route through the PII proxy.
# Set to 1 to accept this trade-off; otherwise startup refuses remote memory.
MEMORY_ALLOW_REMOTE_PII=
MEMORY_MAX_CONTEXT_TOKENS=2000
# Chat context window budget — truncates messages[] sent to LLM (chars, ≈ /4 tokens)
CHAT_CONTEXT_BUDGET_CHARS=60000
# Max number of raw chat_messages loaded into the LLM context window.
# Applies to both the web UI (GET /api/messages) and the Discord bot.
# The char-based CHAT_CONTEXT_BUDGET_CHARS above trims further if needed.
CHAT_HISTORY_LIMIT=500
# Auto-delete chat_messages older than this many days on server startup.
# 0 (or unset) = keep forever. Set to e.g. 30 to enable retention cleanup.
CHAT_HISTORY_RETENTION_DAYS=0
# Discord bot (DM-only, whitelist-gated)
# DISCORD_BOT_TOKEN=              # Bot token from https://discord.com/developers/applications
# DISCORD_ALLOWED_USER_IDS=       # Comma-separated Discord user IDs (Developer Mode → right-click → Copy ID)
# DISCORD_REQUEST_TIMEOUT_MS=300000  # Request timeout in ms (default 300000 = 5 min)
# ---- Emails (Phase 4F) ----
# JSON array of IMAP accounts; empty/missing disables the feature.
# For Gmail: enable 2FA, generate app-password (https://myaccount.google.com/apppasswords)
# For iCloud: https://support.apple.com/en-us/102654
IMAP_ACCOUNTS=[]
# Kill switch — false disables poller + digest handler regardless of IMAP_ACCOUNTS
EMAIL_ENABLED=true
# IMAP poll interval per account, ms (default 5 min, min 1 s)
EMAIL_POLL_INTERVAL_MS=300000
# Importance cutoff on the scorer's 1–5 scale: emails scored >= this are surfaced
# (become pending); below it they're scored and dropped. 3 = "worth noticing" and
# up; 4 = action-required and up.
EMAIL_IMPORTANCE_CUTOFF=3            # range 1–5, else default 3
# Minimum undelivered pending emails required to fire a digest
EMAIL_DIGEST_THRESHOLD=3
# Minimum gap between digest publishes, ms (default 2 h)
EMAIL_DIGEST_COOLDOWN_MS=7200000
# Local hour when evening quiet-window starts (0-23). Morning release is tied
# to the morning-brief handler publishing; if no brief publishes within 7 days,
# 09:00 local is used as a fallback so digests don't hang forever.
EMAIL_QUIET_HOUR_START=22
# EMAIL_URGENT_ENABLED=true  # immediate Discord ping for importance=5 emails
# Consecutive failed poll ticks before an account is flagged "blind" and a
# one-shot Discord alert fires (reset by the next successful poll). Default 3
# (≈15 min at the 5-min interval). Range 1–100.
EMAIL_ACCOUNT_BLIND_ALERT_AFTER=3
# Hold zone for outgoing email drafts in seconds (0-300, default 30).
# 0 = bypass hold and send immediately (kill switch — restores
# pre-iter-3 behaviour without code changes). 300 = 5 min max, kept
# under Discord's 15-min ephemeral webhook window.
EMAIL_SEND_HOLD_SECONDS=30

# ---- Email implicit feedback — silence-as-data (Pain #1 iter 4) ----
# Learn from how you react to urgent pings: R2 observes (via IMAP flags) whether
# you replied (\Answered), read-but-ignored (\Seen, no reply), or never opened a
# pinged email, aggregates per sender, and auto-demotes senders you keep ignoring
# to the digest (a TTL'd auto-suppression rule, visible via /why, self-healing on
# reply). Downgrade-only, sender-level. Disabled by default → zero behaviour
# change. Out-of-range values silently fall back to the default shown (see envInt).
EMAIL_FEEDBACK_ENABLED=false
# Hours after a ping before an unanswered email finalizes as read/ignored.
EMAIL_FEEDBACK_IGNORE_HOURS=24       # range 1–168, else default 24
# Negative outcomes (ignored + read) per sender that trigger auto-suppression.
EMAIL_FEEDBACK_SUPPRESS_AFTER=3      # range 1–20, else default 3
# TTL of an auto-suppression rule, days (also the negative-count lookback window).
EMAIL_FEEDBACK_SUPPRESS_TTL_DAYS=7   # range 1–90, else default 7
# Cap on unresolved emails re-polled for flags per account per tick (IMAP cost).
EMAIL_FEEDBACK_MAX_REPOLL=50         # range 1–500, else default 50

# ---- Digital Observer — macOS only (Pain #2 iter 1) ----
# Polls foreground app+title every 30s via osascript, stores in
# SQLite. macOS Automation permission required first run (System
# Settings → Privacy & Security → Automation → R2 → System Events).
# Disabled by default.
# Out-of-range values for the settings below silently fall back to the default
# shown here — they are NOT clamped to the bound (see envInt in index.ts).
WINDOW_LOGGER_ENABLED=false
WINDOW_LOGGER_INTERVAL_MS=30000      # valid range 5000–300000, else default 30000
# Consecutive blind ticks (null/timeout/throw from osascript) before a one-time
# "observer blind" warning + Discord ping. Resets on the next good sample. At a
# 30s interval, 10 ≈ 5 min.
WINDOW_LOGGER_BLIND_ALERT_AFTER=10   # range 1–2880, else default 10
# ---- Old context-switch "restore when you come back" handler ----
# Superseded by the proactive distraction-pullback handler below. Kept in the
# codebase but silent by default — set CONTEXT_SWITCH_ENABLED=true to re-enable.
CONTEXT_SWITCH_ENABLED=false
# Context-switch detection thresholds
CONTEXT_SWITCH_LONG_SESSION_MIN=30   # "was working" threshold; range 10–240, else default
CONTEXT_SWITCH_GAP_MIN=5             # away that long = real switch; range 1–60, else default
CONTEXT_SWITCH_STABLE_NEW_MIN=5      # confirm return before pinging; range 1–60, else default
CONTEXT_SWITCH_DEDUPE_WINDOW_H=8     # don't re-ping for N hours; range 1–168, else default

# ---- Distraction-pullback — macOS only (Pain #2 iter 2) ----
# Proactive "catch the залип in the moment": a cheap app-level dwell filter
# wakes an LLM judge (titles only) that pings you on a confident "distracted".
# Needs WINDOW_LOGGER_ENABLED=true (it reads window_history) + a live Discord
# bot. Disabled by default. Out-of-range values fall back to the default shown.
DISTRACTION_ENABLED=false
DISTRACTION_DWELL_MIN=25             # ping only after N min in one app; range 5–240, else default
DISTRACTION_WORK_LOOKBACK_MIN=120    # look back for a prior work session; range 10–480, else default
DISTRACTION_JUDGE_LOOKBACK_MIN=60    # timeline window fed to the judge; range 10–480, else default
DISTRACTION_DEDUPE_H=3               # don't re-ping same dwell for N hours; range 1–168, else default
DISTRACTION_REEVAL_MIN=30            # re-judge a dwell after it grows N min; range 5–240, else default
DISTRACTION_CONFIDENCE_PCT=70        # min judge confidence to ping; range 0–100, else default
DISTRACTION_SNOOZE_MIN=60            # "Отстань" button mutes for N min; range 5–480, else default
DISTRACTION_DAILY_LLM_CAP=40         # max judge calls per day; range 1–1000, else default
DISTRACTION_JUDGE_MODEL=claude-haiku-4-5   # judge model (string, default claude-haiku-4-5)

# ---- Weather (Open-Meteo) ----
# Key-less, single-endpoint forecast by coordinates. When enabled: the morning
# brief embeds a deterministic 3-day outlook (no more web_search for weather)
# and the on-demand `weather` tool is registered. Coordinates are geocoded once
# from the stored user.city/user.location fact and cached in memory_facts;
# WEATHER_LAT/LON below pin them manually (use when Open-Meteo doesn't know a
# small village — see docs plan Post-Completion). Disabled by default; when off,
# the brief renders "погода недоступна" and the tool reports "not enabled".
# Out-of-range values fall back to the default shown (envInt).
WEATHER_ENABLED=false
WEATHER_TZ=Europe/Kyiv               # forecast timezone (string)
# WEATHER_LAT=49.6                   # optional manual coordinate override (both required)
# WEATHER_LON=36.9
# ---- Weather alerts (proactive change ping) ----
# Needs WEATHER_ENABLED=true, resolvable coordinates, and a live Discord bot.
# Fires a Discord ping on a sharp change (temp swing / incoming rain / frost /
# storm-wind), deduped per event, suppressed during quiet hours. Disabled by default.
WEATHER_ALERT_ENABLED=false
WEATHER_TEMP_SWING_C=8               # day-over-day Δ°C that counts as a swing; range 1–30, else default
WEATHER_PRECIP_PROB_PCT=60           # precip probability % that counts as "rain coming"; range 0–100, else default
WEATHER_LEAD_HOURS=6                 # intraday look-ahead window (hours); range 1–48, else default
WEATHER_CHECK_INTERVAL_H=3           # min hours between forecast checks; range 1–24, else default
WEATHER_ALERT_DEDUPE_H=12            # don't re-ping the same event for N hours; range 1–168, else default
WEATHER_QUIET_START=22               # no pings at/after this local hour; range 0–23, else default
WEATHER_QUIET_END=8                  # no pings before this local hour; range 0–23, else default

# ---- Cognition push re-delivery (resilience) ----
# Proactive pushes (morningBrief, emailDigest, …) are DM'd to the owner. If the
# DM send fails (transient network/DNS outage — Discord unreachable) the run
# stays published_at=NULL with no retry, so the push was lost forever. R2 now
# persists the publish payload and re-delivers any undelivered run when the
# Discord client (re)connects (shardReady/shardResume) or restarts (clientReady).
# Idempotent (only published_at IS NULL). This window bounds how old an
# undelivered run may be and still be re-sent (so a stale brief is never
# surfaced). Out-of-range values are clamped to the 5m..48h bound.
REDELIVER_MAX_AGE_MS=21600000        # max age (ms) of an undelivered push still re-delivered; default 6h, clamp 5m (300000)..48h (172800000)
