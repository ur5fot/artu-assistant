ANTHROPIC_API_KEY=sk-ant-...
# Server port (used by server + client proxy in vite.config.ts)
PORT=3001
# Client dev server port (used by Vite + server CORS)
CLIENT_PORT=5173
# Claude model (default: claude-sonnet-4-6)
# Options: claude-sonnet-4-6, claude-opus-4-6
CLAUDE_MODEL=claude-sonnet-4-6
# Max output tokens (default: 16384)
CLAUDE_MAX_TOKENS=16384
# Extended thinking budget in tokens (default: 10240)
CLAUDE_THINKING_BUDGET=10240
# SearXNG URL (default: http://localhost:8888)
SEARXNG_URL=http://localhost:8888
# SQLite database path (default: ./data/r2.db)
DB_PATH=./data/r2.db
# Root directory for file operations (default: ~/Documents/r2)
R2_FILES_ROOT=~/Documents/r2
# PII Gateway (Phase 2C)
# Mode: required (blocks without Presidio) | optional (warn + pass-through) | disabled
PII_MODE=optional
# Encryption key for PII token vault (auto-generated on first run if empty)
PII_ENCRYPTION_KEY=
# Entity types to detect (comma-separated Presidio entity names)
PII_ENTITY_TYPES=EMAIL_ADDRESS,PHONE_NUMBER,CREDIT_CARD,IBAN_CODE
# Comma-separated list of languages for PII detection.
# Each language adds one analyzer HTTP call per anonymization request.
# Requires the custom Presidio image with spaCy models for ru/uk (see presidio/Dockerfile).
PII_LANGUAGES=en,ru,uk
# Presidio service URLs
PRESIDIO_ANALYZER_URL=http://localhost:5002
PRESIDIO_ANONYMIZER_URL=http://localhost:5001
# All available Presidio entity types:
# EMAIL_ADDRESS, PHONE_NUMBER, CREDIT_CARD, IBAN_CODE, IP_ADDRESS,
# PERSON, LOCATION, DATE_TIME, NRP, MEDICAL_LICENSE,
# US_SSN, US_DRIVER_LICENSE, UK_NHS, SG_NRIC_FIN, AU_ABN,
# AU_ACN, AU_TFN, AU_MEDICARE, US_PASSPORT, US_BANK_NUMBER
# Supervisor (Phase 3A)
R2_SUPERVISOR_PORT=3100
R2_SHUTDOWN_TIMEOUT=5000
# Client WebSocket URL for supervisor status (set in production)
VITE_SUPERVISOR_WS_URL=ws://localhost:3100
# Phase 3C: Code task
R2_DEV_WORKTREE_PREFIX=/tmp/r2-dev-
R2_DEV_BRANCH=dev
R2_DEV_BASE_BRANCH=master
R2_RALPHEX_MAX_ITERATIONS=20
# Phase 3D: Git watcher + auto-deploy
R2_GIT_POLL_INTERVAL=60000       # ms; 0 = disable watcher
R2_GIT_WATCH_BRANCH=master       # branch to watch for external changes
R2_GIT_REPO_PATH=                # optional, defaults to project root
# Phase 3E: Eval system
EVAL_CONCURRENCY=3
EVALS_PATH=./data/evals.json
# Phase 4G: Local LLM router
LOCAL_LLM_MODE=enabled            # enabled | disabled (gates chat router; memory falls back to Voyage/Claude when disabled)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_MS=45000
# Set to 1 to allow OLLAMA_URL on non-loopback hosts. Without this, startup
# refuses non-loopback URLs because the Ollama path bypasses PII anonymization.
OLLAMA_ALLOW_REMOTE=
# Memory system — indexes chat history into a local sqlite-vec DB. Embeddings
# come from Ollama (mxbai-embed-large, 1024-dim) or Voyage AI (voyage-3, 1024-dim);
# fact extraction comes from Ollama (qwen2.5:7b) or Claude (Haiku). See
# README "Running R2 without Ollama" for the API-only configuration.
MEMORY_ENABLED=true
# embedding/text provider selection. Note: there is no runtime ping — selection
# is based on env, not Ollama reachability. For full API-only mode, set both
# explicitly (see README "Running R2 without Ollama").
#   EMBEDDING_PROVIDER=auto   → Ollama (set 'voyage' explicitly to use Voyage)
#   MEMORY_TEXT_PROVIDER=auto → Ollama unless LOCAL_LLM_MODE=disabled, then Claude
EMBEDDING_PROVIDER=auto                                  # auto | ollama | voyage
MEMORY_TEXT_PROVIDER=auto                                # auto | ollama | claude
MEMORY_EMBED_MODEL=mxbai-embed-large                     # Ollama embed model (must be 1024-dim)
MEMORY_EXTRACT_MODEL=qwen2.5:7b                          # Ollama extractor model
MEMORY_EXTRACT_MODEL_CLAUDE=claude-haiku-4-5-20251001    # Claude extractor model
# Voyage AI (required when EMBEDDING_PROVIDER=voyage; sign up at https://www.voyageai.com/)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3                                    # voyage-3 | voyage-3-large (both 1024-dim)
# Required acknowledgment when memory uses Voyage or Claude. Raw chat content
# and extracted facts (incl. any PII) flow to those providers without
# anonymization — the memory pipeline does not route through the PII proxy.
# Set to 1 to accept this trade-off; otherwise startup refuses remote memory.
MEMORY_ALLOW_REMOTE_PII=
MEMORY_MAX_CONTEXT_TOKENS=2000
# Chat context window budget — truncates messages[] sent to LLM (chars, ≈ /4 tokens)
CHAT_CONTEXT_BUDGET_CHARS=60000
# Max number of raw chat_messages loaded into the LLM context window.
# Applies to both the web UI (GET /api/messages) and the Discord bot.
# The char-based CHAT_CONTEXT_BUDGET_CHARS above trims further if needed.
CHAT_HISTORY_LIMIT=500
# Auto-delete chat_messages older than this many days on server startup.
# 0 (or unset) = keep forever. Set to e.g. 30 to enable retention cleanup.
CHAT_HISTORY_RETENTION_DAYS=0
# Discord bot (DM-only, whitelist-gated)
# DISCORD_BOT_TOKEN=              # Bot token from https://discord.com/developers/applications
# DISCORD_ALLOWED_USER_IDS=       # Comma-separated Discord user IDs (Developer Mode → right-click → Copy ID)
# DISCORD_REQUEST_TIMEOUT_MS=300000  # Request timeout in ms (default 300000 = 5 min)
# ---- Emails (Phase 4F) ----
# JSON array of IMAP accounts; empty/missing disables the feature.
# For Gmail: enable 2FA, generate app-password (https://myaccount.google.com/apppasswords)
# For iCloud: https://support.apple.com/en-us/102654
IMAP_ACCOUNTS=[]
# Kill switch — false disables poller + digest handler regardless of IMAP_ACCOUNTS
EMAIL_ENABLED=true
# IMAP poll interval per account, ms (default 5 min, min 1 s)
EMAIL_POLL_INTERVAL_MS=300000
# Minimum undelivered pending emails required to fire a digest
EMAIL_DIGEST_THRESHOLD=3
# Minimum gap between digest publishes, ms (default 2 h)
EMAIL_DIGEST_COOLDOWN_MS=7200000
# Local hour when evening quiet-window starts (0-23). Morning release is tied
# to the morning-brief handler publishing; if no brief publishes within 7 days,
# 09:00 local is used as a fallback so digests don't hang forever.
EMAIL_QUIET_HOUR_START=22
# EMAIL_URGENT_ENABLED=true  # immediate Discord ping for importance=5 emails
